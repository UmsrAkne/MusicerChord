<Window
    x:Class="MusicerChord.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:MusicerChord.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:MusicerChord.Models"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:viewModels="clr-namespace:MusicerChord.ViewModels"
    Title="{Binding Title}"
    Width="1200"
    Height="720"
    d:DataContext="{d:DesignInstance viewModels:MainWindowViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="300"
    d:DesignWidth="800"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">

    <Grid Background="{StaticResource DeepBackgroundBrush}">

        <Grid.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
                <Setter Property="Foreground" Value="{StaticResource CommonForegroundBrush}" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <StackPanel
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2">
            <Border
                Padding="6,2"
                Background="{StaticResource DarkBackgroundBrush}"
                CornerRadius="5">
                <TextBlock Text="{Binding RootPath}" />
            </Border>

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Width="70"
                    Margin="5"
                    Command="{Binding SoundListViewModel.SortPlayCountAscendingCommand}"
                    ToolTip="Sort by play count (ASC)">
                    <Button.Content>
                        <materialDesign:PackIcon
                            Width="25"
                            Height="25"
                            Kind="SortNumericAscending" />
                    </Button.Content>
                </Button>

                <Button
                    Width="70"
                    Margin="5"
                    Command="{Binding SoundListViewModel.ShuffleSoundListCommand}"
                    ToolTip="Shuffle">
                    <Button.Content>
                        <materialDesign:PackIcon
                            Width="25"
                            Height="25"
                            Kind="Shuffle" />
                    </Button.Content>
                </Button>

                <Button Margin="5" Command="{Binding SoundListViewModel.ReverseSoundListCommand}">
                    <Button.Content>
                        <TextBlock
                            FontWeight="ExtraBold"
                            Foreground="Black"
                            Text="Rev" />
                    </Button.Content>
                </Button>
            </StackPanel>
        </StackPanel>

        <controls:CustomTreeView
            Grid.Row="1"
            Grid.Column="0"
            DataContext="{Binding DirectoryTreeViewModel}"
            SelectedItem="{Binding SelectedContainer}" />

        <ListBox
            x:Name="MusicList"
            Grid.Row="1"
            Grid.Column="1"
            HorizontalContentAlignment="Stretch"
            ItemsSource="{Binding SoundListViewModel.SoundFiles}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:SoundFile}">
                    <controls:SoundListRow DataContext="{Binding}" />
                </DataTemplate>
            </ListBox.ItemTemplate>

            <ListBox.ItemContainerStyle>
                <Style BasedOn="{StaticResource {x:Type ListBoxItem}}" TargetType="ListBoxItem">
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Padding" Value="1" />

                    <Setter Property="Template">
                        <Setter.Value>

                            <ControlTemplate TargetType="ListBoxItem">
                                <materialDesign:Card
                                    x:Name="TemplateRoot"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    ClipToBounds="True"
                                    UniformCornerRadius="6">

                                    <materialDesign:Ripple
                                        Padding="{TemplateBinding Padding}"
                                        HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                        Feedback="LightSkyBlue">

                                        <ContentPresenter />
                                    </materialDesign:Ripple>
                                </materialDesign:Card>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="TemplateRoot" Property="Background" Value="{StaticResource SelectionBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TemplateRoot" Property="Background" Value="{StaticResource HoverBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>

                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <Border
            Grid.Row="3"
            Grid.Column="0"
            Grid.ColumnSpan="2">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding SoundListViewModel.SoundPlayerService.CrossfadeController.CurrentSoundName}" />
                    <TextBlock Margin="10,0" Text="/" />
                    <TextBlock Text="{Binding SoundListViewModel.SoundPlayerService.CrossfadeController.CurrentPlaybackTimeText}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button
                        Width="100"
                        HorizontalAlignment="Left"
                        Command="{Binding SoundListViewModel.PlayCommand}"
                        Content="Play" />

                    <Button
                        Width="100"
                        Margin="10,0"
                        HorizontalAlignment="Left"
                        Command="{Binding SoundListViewModel.StopCommand}"
                        Content="Stop" />

                    <TextBlock
                        Margin="40,0,5,0"
                        VerticalAlignment="Center"
                        Text="Volume: " />

                    <Slider
                        Width="250"
                        Margin="10,0"
                        VerticalAlignment="Center"
                        Maximum="1.0"
                        Minimum="0"
                        TickFrequency="0.01"
                        Ticks="0.01"
                        Value="{Binding SoundListViewModel.SoundPlayerService.CrossfadeController.Volume}" />

                    <TextBlock
                        Margin="10,0"
                        VerticalAlignment="Center"
                        Text="{Binding SoundListViewModel.SoundPlayerService.CrossfadeController.Volume, StringFormat={}{0:0.00}}" />
                </StackPanel>

            </StackPanel>
        </Border>

    </Grid>
</Window>