<UserControl
    x:Class="MusicerChord.Controls.SoundListRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:MusicerChord.Models"
    d:DataContext="{d:DesignInstance models:SoundFile}"
    d:DesignHeight="40"
    d:DesignWidth="600"
    mc:Ignorable="d">

    <Border
        Padding="3"
        BorderBrush="{StaticResource MiddleBackgroundBrush}"
        BorderThickness="1"
        CornerRadius="4">

        <Grid>
            <Grid.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
                    <Setter Property="Foreground" Value="{StaticResource CommonForegroundBrush}" />
                </Style>
            </Grid.Resources>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Border
                    Width="50"
                    Padding="4,0"
                    Background="{StaticResource DarkBackgroundAlphaBrush}"
                    CornerRadius="4">
                    <TextBlock VerticalAlignment="Center" Text="{Binding LineNumber}" />
                </Border>
                <materialDesign:PackIcon
                    Width="20"
                    Height="20"
                    Margin="5,0"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource AccentLightBrush}"
                    Kind="MusicCircle">
                    <materialDesign:PackIcon.Style>
                        <Style TargetType="materialDesign:PackIcon">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Playing}" Value="True">
                                    <Setter Property="Opacity" Value="0.9" />
                                </DataTrigger>

                                <DataTrigger Binding="{Binding Playing}" Value="False">
                                    <Setter Property="Opacity" Value="0.1" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </materialDesign:PackIcon.Style>
                </materialDesign:PackIcon>
            </StackPanel>

            <TextBlock
                Grid.Column="1"
                Margin="6,0"
                VerticalAlignment="Center"
                Text="{Binding FileNameWithoutExtension}" />

            <Border
                Grid.Column="2"
                Width="50"
                Margin="4,0"
                Padding="8,0"
                Background="{StaticResource DarkBackgroundAlphaBrush}"
                CornerRadius="4">

                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSkip}" Value="true">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding IsSkip}" Value="false">
                                <Setter Property="Visibility" Value="Hidden" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="PaleVioletRed"
                    Text="SKIP" />
            </Border>

            <Border
                Grid.Column="3"
                Width="60"
                Margin="4,0"
                Padding="8,0"
                Background="{StaticResource DarkBackgroundAlphaBrush}"
                CornerRadius="4">
                <TextBlock VerticalAlignment="Center" Text="{Binding PlayCount}" />
            </Border>

            <Border
                Grid.Column="4"
                Padding="8,0"
                Background="{StaticResource DarkBackgroundAlphaBrush}"
                CornerRadius="4">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Text="{Binding DurationText}" />
            </Border>

        </Grid>

    </Border>
</UserControl>