<UserControl
    x:Class="MusicerChord.Controls.SoundListRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MusicerChord.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:MusicerChord.Models"
    d:DataContext="{d:DesignInstance models:SoundFile}"
    d:DesignHeight="40"
    d:DesignWidth="600"
    mc:Ignorable="d">

    <Border
        Padding="3"
        BorderBrush="{StaticResource MiddleBackgroundBrush}"
        BorderThickness="1"
        CornerRadius="4">

        <Grid>
            <Grid.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
                    <Setter Property="Foreground" Value="{StaticResource CommonForegroundBrush}" />
                </Style>
            </Grid.Resources>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Width="50"
                Padding="4,0"
                Background="{StaticResource DarkBackgroundAlphaBrush}"
                CornerRadius="4">
                <TextBlock VerticalAlignment="Center" Text="{Binding LineNumber}" />
            </Border>

            <TextBlock
                Grid.Column="1"
                Margin="6,0"
                VerticalAlignment="Center"
                Text="{Binding FileNameWithoutExtension}" />

            <Border
                Grid.Column="2"
                Width="60"
                Margin="4,0"
                Padding="8,0"
                Background="{StaticResource DarkBackgroundAlphaBrush}"
                CornerRadius="4">
                <TextBlock VerticalAlignment="Center" Text="{Binding PlayCount}" />
            </Border>

            <Border
                Grid.Column="3"
                Padding="8,0"
                Background="{StaticResource DarkBackgroundAlphaBrush}"
                CornerRadius="4">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Text="{Binding DurationText}" />
            </Border>

        </Grid>

    </Border>
</UserControl>